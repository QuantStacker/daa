#include <stdio.h>

#define MAX 100
#define INF 9999

int main() {
    int n, graph[MAX][MAX];
    int selected[MAX] = {0};
    int no_edge = 0;
    int total = 0;

    printf("Enter number of vertices (max 100): ");
    scanf("%d", &n);

    printf("Enter the adjacency matrix (0 for no edge):\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &graph[i][j]);
        }
    }

    selected[0] = 1; // Start from vertex 0

    printf("\nEdge : Weight\n");

    while (no_edge < n - 1) {
        int min = INF;
        int x = 0, y = 0;

        for (int i = 0; i < n; i++) {
            if (selected[i]) {
                for (int j = 0; j < n; j++) {
                    if (!selected[j] && graph[i][j]) {
                        if (min > graph[i][j]) {
                            min = graph[i][j];
                            x = i;
                            y = j;
                        }
                    }
                }
            }
        }

        printf("%d - %d : %d\n", x, y, graph[x][y]);
        total += graph[x][y];

        selected[y] = 1;
        no_edge++;
    }

    printf("\nTotal weight of MST : %d\n", total);

    return 0;
}
