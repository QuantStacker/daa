#include <stdio.h>

struct job {
    int id;
    int deadline;
    int profit;
};

// Sort jobs by profit (descending)
void sort(struct job jobs[], int n) {
    int i, j;
    struct job temp;

    for(i = 0; i < n-1; i++) {
        for(j = 0; j < n-i-1; j++) {
            if(jobs[j].profit < jobs[j+1].profit) {
                temp = jobs[j];
                jobs[j] = jobs[j+1];
                jobs[j+1] = temp;
            }
        }
    }
}

int main() {
    int n, i, j, maxDeadline = 0;

    printf("Enter number of jobs: ");
    scanf("%d", &n);

    struct job jobs[n];

    // Input
    for(i = 0; i < n; i++) {
        printf("Enter job ID, deadline & profit for job %d:\n", i+1);
        scanf("%d %d %d", &jobs[i].id, &jobs[i].deadline, &jobs[i].profit);

        if(jobs[i].deadline > maxDeadline)
            maxDeadline = jobs[i].deadline;
    }

    // Sort jobs by profit
    sort(jobs, n);

    int timeslot[maxDeadline + 1];

    // Initialize slots
    for(i = 1; i <= maxDeadline; i++)
        timeslot[i] = -1;

    int totalProfit = 0;

    // Greedy job sequencing
    for(i = 0; i < n; i++) {
        for(j = jobs[i].deadline; j >= 1; j--) {
            if(timeslot[j] == -1) {
                timeslot[j] = jobs[i].id;
                totalProfit += jobs[i].profit;
                break;
            }
        }
    }

    // Output like your notebook
    printf("\nJob Sequence is:\n");
    for(i = 1; i <= maxDeadline; i++) {
        if(timeslot[i] != -1)
            printf("Job %d at time slot %d\n", timeslot[i], i);
    }

    printf("\nTotal profit = %d\n", totalProfit);

    return 0;
}
